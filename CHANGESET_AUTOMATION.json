    {
      "id": "HIGH-002",
      "priority": "P1",
      "title": "Add ViewModel lifecycle management (Desktop)",
      "file": "desktop/src/main/kotlin/com/nexopos/desktop/ui/pos/POSViewModel.kt",
      "estimated_hours": 2,
      "action": "MODIFY",
      "changes": [
        {
          "type": "MODIFY_FIELD",
          "line": 22,
          "old": "private val scope = CoroutineScope(Dispatchers.Main)",
          "new": "private val scope = CoroutineScope(SupervisorJob() + Dispatchers.Main)"
        },
        {
          "type": "ADD_FUNCTION",
          "function": "onCleared",
          "code": "fun onCleared() {\n    scope.cancel()\n    println(\"[POSViewModel] Cleared and cancelled coroutines\")\n}"
        }
      ]
    },
    {
      "id": "HIGH-003",
      "priority": "P1",
      "title": "Add HTTP response caching",
      "file": "app/src/main/java/com/nexopos/mobile/core/network/ServiceLocator.kt",
      "estimated_hours": 3,
      "action": "MODIFY",
      "changes": [
        {
          "type": "ADD_DEPENDENCY",
          "gradle_file": "app/build.gradle.kts",
          "dependency": "implementation(\"com.squareup.okhttp3:okhttp-urlconnection:4.12.0\")"
        },
        {
          "type": "MODIFY_FUNCTION",
          "function": "client",
          "add_interceptor": "Cache(context.cacheDir, 10 * 1024 * 1024)",
          "add_cache_control": "CacheControl.Builder().maxAge(5, TimeUnit.MINUTES).build()"
        }
      ]
    }
  ],

{
  "audit_metadata": {
    "version": "1.0",
    "date": "2025-12-10",
    "auditor": "Senior Android Architect AI",
    "project": "NexoPOS v5.0",
    "total_issues": 14,
    "critical_issues": 5,
    "estimated_effort_hours": 120
  },
  "critical_fixes": [
    {
      "id": "CRIT-001",
      "priority": "P0",
      "title": "Remove blocking network call in ServiceLocator",
      "file": "app/src/main/java/com/nexopos/mobile/core/network/ServiceLocator.kt",
      "lines": [46],
      "issue": "runBlocking() blocks main thread during HTTP client initialization",
      "risk_level": "CRITICAL",
      "impact": "ANR on Android, poor UX",
      "estimated_hours": 2,
      "action": "MODIFY",
      "changes": [
        {
          "type": "ADD_FIELD",
          "line": 25,
          "code": "@Volatile\nprivate var cachedToken: String? = null"
        },
        {
          "type": "MODIFY_FUNCTION",
          "function": "authInterceptor",
          "old_signature": "private fun authInterceptor(token: String)",
          "new_signature": "private fun authInterceptor(repo: SettingsRepository)",
          "implementation": "Get token from cache or settings lazily"
        },
        {
          "type": "MODIFY_FUNCTION",
          "function": "client",
          "line": 44,
          "remove": "val token = runBlocking { repo.tokenFlow.first() }",
          "add": "// Token fetched lazily in interceptor"
        },
        {
          "type": "MODIFY_FUNCTION",
          "function": "clearApiCache",
          "add_line": "cachedToken = null"
        }
      ],
      "testing_required": [
        "Verify API calls still work",
        "Test token refresh scenario",
        "Verify no ANR with StrictMode"
      ]
    },
    {
      "id": "CRIT-002",
      "priority": "P0",
      "title": "Implement proper database migrations",
      "file": "app/src/main/java/com/nexopos/mobile/core/db/AppDatabase.kt",
      "lines": [32, 55],
      "issue": "fallbackToDestructiveMigration() deletes all user data on schema changes",
      "risk_level": "CRITICAL",
      "impact": "Users lose all offline orders on app update",
      "estimated_hours": 4,
      "action": "MODIFY",
      "changes": [
        {
          "type": "MODIFY_ANNOTATION",
          "line": 32,
          "old": "version = 4",
          "new": "version = 5"
        },
        {
          "type": "ADD_MIGRATION",
          "line": 45,
          "migration_name": "MIGRATION_4_5",
          "sql_commands": [
            "CREATE TABLE products_new (...)",
            "INSERT INTO products_new SELECT * FROM products",
            "DROP TABLE products",
            "ALTER TABLE products_new RENAME TO products",
            "CREATE INDEX index_products_barcode ON products(barcode)",
            "CREATE INDEX index_products_category_id ON products(category_id)"
          ]
        },
        {
          "type": "MODIFY_BUILDER",
          "line": 55,
          "remove": ".fallbackToDestructiveMigration()",
          "add": ".addMigrations(MIGRATION_4_5)\n.fallbackToDestructiveMigrationOnDowngrade()"
        }
      ],
      "testing_required": [
        "Test migration with version 4 database",
        "Verify all data preserved",
        "Test rollback scenario"
      ]
    },
    {
      "id": "CRIT-003",
      "priority": "P0",
      "title": "Make base URL configurable",
      "files": [
        "app/src/main/java/com/nexopos/mobile/core/network/ServiceLocator.kt",
        "app/src/main/java/com/nexopos/mobile/core/prefs/SettingsRepository.kt",
        "desktop/src/main/kotlin/com/nexopos/desktop/core/prefs/Settings.kt"
      ],
      "issue": "Hardcoded http://localhost/ prevents connecting to real server",
      "risk_level": "CRITICAL",
      "impact": "Cannot use in production",
      "estimated_hours": 1,
      "action": "MODIFY",
      "changes": [
        {
          "file": "SettingsRepository.kt",
          "type": "ADD_FIELD",
          "code": "val baseUrlFlow: Flow<String> = dataStore.data.map { prefs ->\n    prefs[BASE_URL_KEY] ?: \"https://api.nexopos.com/\"\n}"
        },
        {
          "file": "ServiceLocator.kt",
          "type": "MODIFY_FUNCTION",
          "function": "getRetrofit",
          "line": 84,
          "old": ".baseUrl(\"http://localhost/\")",
          "new": ".baseUrl(runBlocking { repo.baseUrlFlow.firstOrNull() ?: \"https://api.nexopos.com/\" })"
        }
      ]
    },
    {
      "id": "CRIT-004",
      "priority": "P0",
      "title": "Switch to HTTPS protocol",
      "files": ["All network configuration files"],
      "issue": "HTTP protocol vulnerable to MITM attacks",
      "risk_level": "CRITICAL",
      "impact": "Credential theft, data interception",
      "estimated_hours": 0.5,
      "action": "FIND_REPLACE",
      "changes": [
        {
          "type": "REGEX_REPLACE",
          "pattern": "http://",
          "replacement": "https://",
          "files": ["**/*.kt"],
          "exclude": ["**/test/**", "**/androidTest/**"]
        }
      ]
    },
    {
      "id": "CRIT-005",
      "priority": "P0",
      "title": "Move shared models to :shared module",
      "files": [
        "app/src/main/java/com/nexopos/mobile/core/network/Models.kt",
        "desktop/src/main/kotlin/com/nexopos/desktop/core/network/Models.kt"
      ],
      "issue": "60% code duplication - same models in both modules",
      "risk_level": "HIGH",
      "impact": "Maintenance nightmare, inconsistent behavior",
      "estimated_hours": 8,
      "action": "MOVE_AND_REFACTOR",
      "changes": [
        {
          "type": "CREATE_FILE",
          "path": "shared/src/main/kotlin/com/nexopos/shared/models/Product.kt",
          "source": "app/.../Models.kt",
          "models": ["Product", "UnitQuantity", "UnitDetail"]
        },
        {
          "type": "CREATE_FILE",
          "path": "shared/src/main/kotlin/com/nexopos/shared/models/Customer.kt",
          "source": "app/.../Models.kt",
          "models": ["Customer"]
        },
        {
          "type": "CREATE_FILE",
          "path": "shared/src/main/kotlin/com/nexopos/shared/models/Order.kt",
          "source": "app/.../OrderModels.kt",
          "models": ["CreateOrderRequest", "OrderProductRequest", "OrderPaymentRequest"]
        },
        {
          "type": "UPDATE_IMPORTS",
          "files": ["app/**/*.kt", "desktop/**/*.kt"],
          "old_import": "com.nexopos.mobile.core.network.Product",
          "new_import": "com.nexopos.shared.models.Product"
        },
        {
          "type": "DELETE_FILE",
          "path": "desktop/src/main/kotlin/com/nexopos/desktop/core/network/Models.kt",
          "reason": "Duplicate - moved to :shared"
        }
      ]
    }
  ],
  "high_priority_fixes": [
    {
      "id": "HIGH-001",
      "priority": "P1",
      "title": "Implement Koin dependency injection",
      "estimated_hours": 16,
